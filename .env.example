APP_ENV=development
APP_NAME="Adaptive Medical RAG"
API_HOST=0.0.0.0
API_PORT=8000
GRADIO_PORT=7860

# PostgreSQL + pgvector Configuration
# Using postgresql+psycopg driver for SQLAlchemy compatibility
DATABASE_URL=postgresql+psycopg://medical_rag:medical_rag@localhost:5432/medical_rag
POSTGRES_DB=medical_rag
POSTGRES_USER=medical_rag
POSTGRES_PASSWORD=change_me

# Embedding Configuration
# EMBEDDING_PROVIDER can be 'local' (using sentence-transformers), 'openai', or 'google'
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# LLM Configuration
# LLM_PROVIDER can be 'openai', 'google', or 'local'
LLM_PROVIDER=google
LLM_MODEL=gemini-1.5-flash
LLM_API_KEY=
LLM_TEMPERATURE=0.0

# RAG & Retrieval Settings
DENSE_TOP_K=30
SPARSE_TOP_K=30
RERANK_TOP_K=12
MAX_RETRIEVAL_ITERATIONS=3
MIN_EVIDENCE_AUTHORITY_SCORE=0.80
MIN_CITATION_SUPPORT_SCORE=0.85

# External Source APIs
PUBMED_API_KEY=
PUBMED_TOOL_NAME=adaptive-medical-rag
PUBMED_CONTACT_EMAIL=

# Safety, Privacy & Compliance
ENABLE_AUDIT_LOGS=true
ENABLE_QUERY_STORAGE=false
DEIDENTIFY_INPUT=true
